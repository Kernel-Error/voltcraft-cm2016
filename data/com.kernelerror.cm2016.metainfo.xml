<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.kernelerror.cm2016</id>

  <name>CM 2016 Manager</name>
  <summary>Voltcraft CM 2016 battery monitor</summary>

  <metadata_license>MIT</metadata_license>
  <project_license>MIT</project_license>

  <developer id="com.kernelerror">
    <name>Kernel-Error</name>
  </developer>

  <description>
    <p>
      Open-source Linux desktop application for monitoring and logging data
      from the Voltcraft Charge Manager CM 2016 battery charger. Replaces the
      Windows-only CM2016 Logger V2.10 software with a native GTK 4 interface.
    </p>
    <p>Features include:</p>
    <ul>
      <li>Real-time monitoring of all 6 charging slots</li>
      <li>Voltage and current charts with zoom and pan</li>
      <li>Data table with filtering and clipboard support</li>
      <li>CSV and spreadsheet export with embedded charts</li>
      <li>Print measurement reports</li>
      <li>Save/load recording sessions with crash recovery</li>
      <li>7 interface languages</li>
    </ul>
  </description>

  <url type="homepage">https://github.com/Kernel-Error/voltcraft-cm2016</url>
  <url type="bugtracker">https://github.com/Kernel-Error/voltcraft-cm2016/issues</url>
  <url type="vcs-browser">https://github.com/Kernel-Error/voltcraft-cm2016</url>

  <branding>
    <color type="primary" scheme_preference="light">#73d216</color>
    <color type="primary" scheme_preference="dark">#2e5a04</color>
  </branding>

  <screenshots>
    <screenshot type="default">
      <caption>Data table with live recording from all 6 slots</caption>
      <image>https://raw.githubusercontent.com/Kernel-Error/voltcraft-cm2016/main/data/screenshots/screenshot-table.png</image>
    </screenshot>
    <screenshot>
      <caption>Voltage and current charts with charge/discharge color coding</caption>
      <image>https://raw.githubusercontent.com/Kernel-Error/voltcraft-cm2016/main/data/screenshots/screenshot-charts.png</image>
    </screenshot>
    <screenshot>
      <caption>Bar chart style</caption>
      <image>https://raw.githubusercontent.com/Kernel-Error/voltcraft-cm2016/main/data/screenshots/screenshot-bar-chart.png</image>
    </screenshot>
  </screenshots>

  <launchable type="desktop-id">com.kernelerror.cm2016.desktop</launchable>

  <provides>
    <binary>cm2016</binary>
  </provides>

  <translation type="gettext">cm2016</translation>

  <requires>
    <display_length compare="ge">800</display_length>
  </requires>

  <recommends>
    <control>keyboard</control>
    <control>pointing</control>
  </recommends>

  <keywords>
    <keyword>battery</keyword>
    <keyword>charger</keyword>
    <keyword>voltcraft</keyword>
    <keyword>NiMH</keyword>
    <keyword>CM2016</keyword>
  </keywords>

  <releases>
    <release version="0.1.0" date="2026-03-21">
      <description>
        <p>Initial release with full feature parity to the Windows CM2016 Logger V2.10.</p>
      </description>
    </release>
  </releases>

  <content_rating type="oars-1.1" />
</component>
